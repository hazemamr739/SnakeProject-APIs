{
  "SeriLog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "F:\\Logs\\log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"

        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properities": {
      "ApplicationName": "GriffinApp"
    }
  },
  "ConnectionStrings": {
    //"DefaultConnection": "Server=.;Database=PlaystationProject;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;Connection Timeout=30;MultipleActiveResultSets=True"
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "SnakeProject.API",
    "Audience": "SnakeProject.Client",
    "DurationInMinutes": 60
  },
  "AdminSeed": {
    "Email": "",
    "Password": "",
    "FirstName": "System",
    "LastName": "Admin"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
